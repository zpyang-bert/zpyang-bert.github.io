---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | json }},
      "subtitle" : {{ post.subtitle | json }},
      "tags"     : {{ post.tags | json }},
      "url"      : {{ post.url | json }},
      "date"     : {{ post.date | json }}
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]